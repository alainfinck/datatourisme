# Caddy configuration for datatourisme
# Proxy requests to the Node.js server while serving static files

:{$PORT} {
    # Serve static files from the dist directory
    root * /app/dist
    file_server

    # Forward specific paths to the backend
    @backend {
        path /socket.io/*
        path /health
        path /contacts.json
        path /contacts.csv
        path /emails.json
        path /datatourisme.csv
    }
    reverse_proxy @backend localhost:3001

    # Fallback all other requests to index.html for SPA
    handle {
        try_files {path} /index.html
    }

    log {
        output stdout
    }
}
